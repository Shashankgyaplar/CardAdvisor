# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/credit-card-advisor
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/credit-card-advisor
MONGODB_URI=mongodb://localhost:27017/credit-card-advisor

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL for CORS (set this in production)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

